

<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LNHWebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LNHWebApp.styles.css" asp-append-version="true" />
    <style>
       
        /* --- Styles Généraux --- */
        .nav-link:hover {
            color: #ffc107 !important;
            transition: 0.3s;
        }

        .dropdown-item:hover {
            background-color: #b11226 !important;
        }

        .navbar-brand img {
            filter: drop-shadow(0px 0px 2px rgba(255,255,255,0.5));
        }

        /* --- Animation des Cartes (Sorti du bloc .toast) --- */
        .transition-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background-color: var(--bs-body-bg);
            position: relative;
            overflow: hidden; /* Pour que le bouton jaune ne dépasse pas bizarrement */
        }

            .transition-card:hover {
                transform: translateY(-8px); /* Légèrement plus visible */
                box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
                cursor: pointer;
            }

        /* --- Gestion des Couleurs par Thème --- */
        [data-bs-theme='dark'] .card-title {
            color: #ffc107;
        }

        [data-bs-theme='light'] .card-title {
            color: #b11226;
        }

        .badge-code {
            background-color: rgba(128, 128, 128, 0.2);
            color: var(--bs-body-color);
            border: 1px solid rgba(128, 128, 128, 0.3);
        }

        /* --- Toasts --- */
        .toast-container {
            pointer-events: none;
        }

        .toast {
            pointer-events: auto;
        }

        /* --- Gestion des Logos Sombre/Clair --- */
        .logo-sombre {
            display: none !important;
        }

        [data-bs-theme='dark'] .logo-clair {
            display: none !important;
        }

        [data-bs-theme='dark'] .logo-sombre {
            display: block !important;
        }
   
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom box-shadow mb-3" style="background-color: #b11226;">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center fw-bold" asp-controller="Equipes" asp-action="Index">
                    <img src="https://upload.wikimedia.org/wikipedia/fr/f/f2/Logo_LNH.svg" alt="logo_lnh" width="45" height="45" class="me-2">
                    <span class="d-none d-sm-inline">GESTION LNH</span>
                </a>

                <span class="badge rounded-pill bg-warning text-dark me-2 border border-dark">@ViewBag.Saison</span>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold" asp-controller="Equipes" asp-action="Index">
                                <i class="bi bi-shield-shaded me-1"></i>ÉQUIPES
                            </a>
                        </li>
                        <li class="nav-item ms-lg-4">
                            <a class="btn btn-outline-warning btn-sm fw-bold border-2 px-3" asp-controller="Equipes" asp-action="EquipeCreer">
                                <i class="bi bi-plus-circle-fill me-1"></i> ÉQUIPE
                            </a>
                        </li>

                        <li class="nav-item dropdown ms-lg-2">
                            <a class="nav-link dropdown-toggle text-white fw-bold btn btn-dark btn-sm px-3" href="#" id="equipeDropdown" role="button" data-bs-toggle="dropdown">
                                SÉLECTIONNER UNE ÉQUIPE
                            </a>
                            <ul class="dropdown-menu shadow-lg border-0 mt-2" aria-labelledby="equipeDropdown"
                                style="background-color: #212529; max-height: 450px; overflow-y: auto; min-width: 250px;">
                                @if (Model is EquipeVM vm && vm.Equipes != null)
        {
            @foreach (var equipe in vm.Equipes)
            {
                <li>
                    <a class="dropdown-item text-white d-flex align-items-center py-2 border-bottom border-secondary"
                       asp-controller="Equipes" asp-action="JoueurParEquipe" asp-route-id="@equipe.Ide">
                        <img src="@equipe.Logo_clair" width="25" height="25" class="me-3" style="object-fit: contain;">
                        <small>@equipe.Nom</small>
                    </a>
                </li>
            }
        }
        else
        {
            @* Ce qui s'affiche sur les pages "Create", "Edit" ou "Details" *@
            <li>
                <a class="dropdown-item text-white" asp-controller="Equipes" asp-action="Index">
                    <i class="bi bi-arrow-left-circle me-2"></i> Retour à la liste complète
                </a>
            </li>
        }
                            </ul>
                            
                        </li>
                    </ul>

                    <form asp-controller="Equipes" asp-action="Recherche" method="get" class="d-flex ms-lg-3 mt-2 mt-lg-0">
                        <div class="input-group">
                            <input type="text" name="requete" class="form-control form-control-sm shadow-none" placeholder="ID Joueur..." required />
                            <button type="submit" class="btn btn-dark btn-sm border-light">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                    <div class="ms-lg-3">
                        <button class="btn btn-outline-light btn-sm shadow-none" id="themeBtn" type="button" onclick="toggleTheme()">
                            <i class="bi bi-sun-fill" id="themeIcon"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    @* --- ZONE DES TOASTS --- *@
    <div class="toast-container position-fixed top-0 end-0 p-4" style="z-index: 2000;">
        @if (TempData["Success"] != null)
        {
            <div class="toast align-items-center text-white bg-success border-0 shadow-lg mb-2" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="toast align-items-center text-white bg-danger border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 bg-light py-3">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold text-dark">LNHWebApp</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialisation de tous les toasts présents dans la page
            var toastElList = [].slice.call(document.querySelectorAll('.toast'))
            var toastList = toastElList.map(function (toastEl) {
                // On les affiche avec un délai de 5 secondes
                var toast = new bootstrap.Toast(toastEl, { delay: 5000, autohide: true });
                toast.show();
                return toast;
            })
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('themeIcon');
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';

            html.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateIcon(newTheme);
        }

        function updateIcon(theme) {
            const icon = document.getElementById('themeIcon');
            if (theme === 'dark') {
                icon.classList.replace('bi-sun-fill', 'bi-moon-stars-fill');
            } else {
                icon.classList.replace('bi-moon-stars-fill', 'bi-sun-fill');
            }
        }

        // Appliquer le thème sauvegardé au chargement
        (function () {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
            updateIcon(savedTheme);
        })();
    </script>
</body>
</html>