@model Tp2LnhWebApp.Models.Equipe

@{
    ViewData["Title"] = "Ajouter une Équipe";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 bg-body-tertiary">

                @* Header avec le rouge caractéristique de la LNH *@
                <div class="card-header text-white text-center py-3" style="background-color: #b11226;">
                    <h3 class="mb-0 text-uppercase fw-bold">
                        <i class="bi bi-shield-plus me-2"></i>Nouvelle Équipe
                    </h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    @* Ajout de enctype="multipart/form-data" pour l'upload *@
                    <form asp-action="EquipeCreer" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            @* Informations de base *@
                            <div class="col-md-8 mb-3">
                                <label asp-for="Nom" class="form-label fw-bold small opacity-75 text-uppercase">Nom de l'équipe</label>
                                <input asp-for="Nom" class="form-control bg-body border-secondary-subtle" placeholder="ex: Canadiens de Montréal" required />
                                <span asp-validation-for="Nom" class="text-danger extra-small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Code" class="form-label fw-bold small opacity-75 text-uppercase">Code (3 lettres)</label>
                                <input asp-for="Code" class="form-control bg-body border-secondary-subtle text-center fw-bold" placeholder="MTL" maxlength="3" required />
                                <span asp-validation-for="Code" class="text-danger extra-small"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold text-danger mb-4">
                            <i class="bi bi-image me-2"></i>Identité Visuelle (Logos)
                        </h5>

                        <div class="row">
                            @* Upload Logo Clair *@
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small opacity-75 text-uppercase">Logo (Fond Clair)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-body-secondary border-secondary-subtle"><i class="bi bi-sun"></i></span>
                                    <input type="file" name="logoClairFile" class="form-control bg-body border-secondary-subtle" accept="images/*" />
                                </div>
                                <div class="form-text extra-small mt-1 text-muted">Version pour fonds blancs/clairs.</div>
                            </div>

                            @* Upload Logo Sombre *@
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small opacity-75 text-uppercase">Logo (Fond Sombre)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-body-secondary border-secondary-subtle"><i class="bi bi-moon-stars"></i></span>
                                    <input type="file" name="logoSombreFile" class="form-control bg-body border-secondary-subtle" accept="images/*" />
                                </div>
                                <div class="form-text extra-small mt-1 text-muted">Version pour fonds noirs/foncés.</div>
                            </div>
                        </div>

                        @* Boutons d'action *@
                        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">
                                <i class="bi bi-x-circle me-2"></i>ANNULER
                            </a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold shadow">
                                <i class="bi bi-plus-circle me-2"></i>CRÉER L'ÉQUIPE
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control:focus {
        border-color: #b11226 !important;
        box-shadow: 0 0 0 0.25rem rgba(177, 18, 38, 0.15);
    }

    /* Style personnalisé pour le bouton de sélection de fichier */
    input[type=file]::file-selector-button {
        background-color: #b11226;
        color: white;
        border: none;
        padding: 0.2rem 1rem;
        margin-right: 0.5rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}