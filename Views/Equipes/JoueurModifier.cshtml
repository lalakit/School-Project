@model Tp2LnhWebApp.Models.Joueur

@{
    ViewData["Title"] = "Modifier " + Model.Nom;
    var estGardien = string.Equals(Model.TypeJoueur, "Gardien", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-lg border-0 bg-body-tertiary">

                <div class="card-header text-white text-center py-3" style="background-color: #b11226;">
                    <h3 class="mb-0 text-uppercase fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Modifier la fiche : @Model.Nom
                    </h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    @* MODIFICATION : Ajout de enctype pour l'upload *@
                    <form asp-action="JoueurModifier" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Idj" />
                        <input type="hidden" asp-for="Ide" />
                        @* IMPORTANT : On garde le chemin actuel de la photo si aucun nouveau fichier n'est choisi *@
                        <input type="hidden" asp-for="Photo" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            @* --- COLONNE GAUCHE : IDENTITÉ & PHYSIQUE --- *@
                            <div class="col-lg-7 border-end-lg">
                                <h5 class="fw-bold text-danger border-bottom pb-2 mb-4">
                                    <i class="bi bi-card-list me-2"></i>Identité & Physique
                                </h5>

                                <div class="row mb-3">
                                    <div class="col-md-9 mb-3">
                                        <label asp-for="Nom" class="form-label fw-bold small opacity-75 text-uppercase">Nom Complet</label>
                                        <input asp-for="Nom" class="form-control bg-body border-secondary-subtle" required />
                                        <span asp-validation-for="Nom" class="text-danger extra-small"></span>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label asp-for="Numero" class="form-label fw-bold small opacity-75 text-uppercase">#</label>
                                        <input asp-for="Numero" type="number" class="form-control bg-body border-secondary-subtle" required />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-8 mb-3">
                                        <label asp-for="ProfilDetails.naissance.date" class="form-label fw-bold small opacity-75 text-uppercase">Date de Naissance</label>
                                        <input asp-for="ProfilDetails.naissance.date" type="date" class="form-control bg-body border-secondary-subtle" required />
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label asp-for="ProfilDetails.age" class="form-label fw-bold small opacity-75 text-uppercase">Âge</label>
                                        <input asp-for="ProfilDetails.age" type="number" class="form-control bg-body border-secondary-subtle" required />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-4 mb-3">
                                        <label asp-for="ProfilDetails.tailleCm" class="form-label fw-bold small opacity-75 text-uppercase">Taille</label>
                                        <div class="input-group">
                                            <input asp-for="ProfilDetails.tailleCm" type="number" class="form-control bg-body border-secondary-subtle" />
                                            <span class="input-group-text bg-body-secondary border-secondary-subtle">cm</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label asp-for="ProfilDetails.poidsKg" class="form-label fw-bold small opacity-75 text-uppercase">Poids</label>
                                        <div class="input-group">
                                            <input asp-for="ProfilDetails.poidsKg" type="number" class="form-control bg-body border-secondary-subtle" />
                                            <span class="input-group-text bg-body-secondary border-secondary-subtle">kg</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label asp-for="Main" class="form-label fw-bold small opacity-75 text-uppercase">Main</label>
                                        <select asp-for="Main" class="form-select bg-body border-secondary-subtle">
                                            <option value="Gauche">Gauche</option>
                                            <option value="Droite">Droite</option>
                                        </select>
                                    </div>
                                </div>

                                @* MODIFICATION : Remplacement de l'URL par l'Upload de fichier *@
                                <div class="mb-3">
                                    <label class="form-label fw-bold small opacity-75 text-uppercase">Changer la Photo (Fichier)</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-body-secondary border-secondary-subtle"><i class="bi bi-image"></i></span>
                                        <input type="file" name="photoFile" class="form-control bg-body border-secondary-subtle" accept="images/*" />
                                    </div>
                                    <div class="form-text small opacity-50">Laissez vide pour conserver la photo actuelle.</div>

                                    @* Aperçu de la photo actuelle *@
                                    @if (!string.IsNullOrEmpty(Model.Photo))
                                    {
                                        <div class="mt-3 text-center">
                                            <p class="extra-small fw-bold text-muted mb-1">Aperçu actuel :</p>
                                            <img src="@Model.Photo" class="rounded shadow-sm border" style="height: 80px; width: auto;" alt="Photo actuelle" />
                                        </div>
                                    }
                                </div>
                            </div>

                            @* --- COLONNE DROITE : POSTE & STATS --- *@
                            <div class="col-lg-5 ps-lg-4 mt-4 mt-lg-0">
                                <h5 class="fw-bold text-danger border-bottom pb-2 mb-4">
                                    <i class="bi bi-graph-up me-2"></i>Poste & Performances
                                </h5>

                                <div class="row mb-4">
                                    <div class="col-6">
                                        <label asp-for="TypeJoueur" class="form-label fw-bold small opacity-75 text-uppercase">Catégorie</label>
                                        <select asp-for="TypeJoueur" class="form-select border-danger fw-bold bg-body">
                                            <option value="Patineur">Patineur</option>
                                            <option value="Gardien">Gardien</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label asp-for="Poste" class="form-label fw-bold small opacity-75 text-uppercase">Position</label>
                                        <select asp-for="Poste" class="form-select bg-body border-secondary-subtle">
                                            <option value="C">Centre (C)</option>
                                            <option value="AG">Ailier Gauche (AG)</option>
                                            <option value="AD">Ailier Droit (AD)</option>
                                            <option value="D">Défenseur (D)</option>
                                            <option value="G">Gardien (G)</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="p-3 border rounded bg-body shadow-sm">
                                    <p class="fw-bold text-danger extra-small mb-3">Statistiques de Saison</p>
                                    <div class="row g-2">
                                        <div class="col-4 mb-2">
                                            <label asp-for="Statistique.matchs" class="form-label extra-small fw-bold">PJ</label>
                                            <input asp-for="Statistique.matchs" type="number" class="form-control form-control-sm bg-body-secondary border-0 text-center fw-bold" />
                                        </div>

                                        @if (estGardien)
                                        {
                                            <div class="col-4 mb-2">
                                                <label asp-for="Statistique.victoires" class="form-label extra-small fw-bold text-success">V</label>
                                                <input asp-for="Statistique.victoires" type="number" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label asp-for="Statistique.pourcentageArrets" class="form-label extra-small fw-bold text-primary">%ARR</label>
                                                <input asp-for="Statistique.pourcentageArrets" type="number" step="0.001" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                            <div class="col-12">
                                                <label asp-for="Statistique.moyenneButsAlloues" class="form-label extra-small fw-bold">MOY. (GAA)</label>
                                                <input asp-for="Statistique.moyenneButsAlloues" type="number" step="0.01" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="col-4 mb-2">
                                                <label asp-for="Statistique.buts" class="form-label extra-small fw-bold">B</label>
                                                <input asp-for="Statistique.buts" type="number" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label asp-for="Statistique.passes" class="form-label extra-small fw-bold">A</label>
                                                <input asp-for="Statistique.passes" type="number" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                            <div class="col-6">
                                                <label asp-for="Statistique.plusMoins" class="form-label extra-small fw-bold">+/-</label>
                                                <input asp-for="Statistique.plusMoins" type="number" class="form-control form-control-sm bg-body-secondary border-0 text-center" />
                                            </div>
                                            <div class="col-6">
                                                <label asp-for="Statistique.points" class="form-label extra-small fw-bold text-warning">PTS</label>
                                                <input asp-for="Statistique.points" type="number" class="form-control form-control-sm bg-dark text-warning border-0 text-center fw-bold" readonly />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* --- BOUTONS D'ACTION --- *@
                        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary-subtle">
                            <a asp-action="JoueurParEquipe" asp-route-id="@Model.Ide" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">
                                <i class="bi bi-x-circle me-2"></i>ANNULER
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow">
                                <i class="bi bi-check-all me-2"></i>CONFIRMER
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control:focus, .form-select:focus {
        border-color: #b11226 !important;
        box-shadow: 0 0 0 0.25rem rgba(177, 18, 38, 0.15);
    }

    input[type=file]::file-selector-button {
        background-color: #b11226;
        color: white;
        border: none;
        padding: 0.2rem 1rem;
        margin-right: 1rem;
        border-radius: 4px;
        cursor: pointer;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}