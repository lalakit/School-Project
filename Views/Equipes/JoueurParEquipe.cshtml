@model TP2LnhWebApp.Models.JoueurVM;

@{
    ViewData["Title"] = "Effectif - " + ViewBag.EquipeCode;
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <div class="d-flex align-items-center">
        <img src="@ViewBag.LogoClair"
             alt="Logo @ViewBag.CodeEquipe"
             style="width: 50px; height: 50px; object-fit: contain;"
             class="me-3" />
        <h2 class="mb-0">@ViewBag.EquipeNom (@ViewBag.CodeEquipe)</h2>
    </div>
    <a asp-action="JoueurCreer" asp-route-id="@ViewBag.Ide" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle me-2"></i>Nouveau Joueur
    </a>
</div>

<div class="card shadow">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-dark text-white">
            <tr>
                <th class="ps-4">Photo</th>
                <th>Joueur</th>
                <th>Poste</th>
                <th>Type</th>
                <th>#</th>
                <th>Points</th>
                <th>Arrêts</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var joueur in Model.Joueurs)
            {
                <tr>
                    <td class="ps-4">
                        <img src="@joueur.Photo" alt=""
                             class="rounded-circle border" style="width:50px; height:50px; object-fit:cover;" />
                    </td>
                    <td>
                        <div class="fw-bold">@joueur.Nom</div>
                        <span class="badge bg-secondary">#@joueur.Idj</span>
                    </td>
                    <td>@joueur.Poste</td>
                    <td>
                        <span class="badge @(joueur.TypeJoueur == "Gardien" ? "bg-warning text-dark" : "bg-info text-dark")">
                            @joueur.TypeJoueur
                        </span>
                    </td>
                    <td class="text-center fw-bold">
                        <div class="fw-bold">@joueur.Numero</div>
                    </td>
                    <td class="text-center fw-bold">
                        <div class="fw-bold">@joueur.Statistique.points</div>
                    </td>
                    <td class="text-center fw-bold">
                        <div class="fw-bold">@joueur.Statistique.pourcentageArrets</div>
                    </td>
                    <td class="text-end pe-4">
                        <div class="btn-group">
                            <a asp-action="JoueurDetails" asp-route-id="@joueur.Idj" asp-route-code="@ViewBag.EquipeCode" class="btn btn-sm btn-outline-secondary" title="Détails">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="JoueurModifier" asp-route-id="@joueur.Idj" class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="JoueurSupprimer" asp-route-id="@joueur.Idj" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-5">
    <ul class="pagination justify-content-center">
        @for (int i = 1; i <= Model.PagesTotales; i++)
        {
            <li class="page-item @(i == Model.PageCourante ? "active" : "")">
                <a class="page-link shadow-sm" asp-action="JoueurParEquipe" asp-route-code="@Model.Joueurs.FirstOrDefault()?.Ide" asp-route-page="@i">@i</a>
            </li>

        }
    </ul>
</nav>


